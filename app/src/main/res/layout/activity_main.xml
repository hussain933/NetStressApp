<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#f0f0f0">

    <EditText
        android:id="@+id/editText"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#ffffff"
        android:gravity="end|center_vertical"
        android:padding="16dp"
        android:textSize="32sp"
        android:inputType="none"
        android:textColor="#000000" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:rowCount="5"
        android:columnCount="4"
        android:layout_marginTop="16dp">

        <Button android:id="@+id/btn_7" android:text="7" android:layout_row="0" android:layout_column="0" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_8" android:text="8" android:layout_row="0" android:layout_column="1" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_9" android:text="9" android:layout_row="0" android:layout_column="2" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_div" android:text="/" android:layout_row="0" android:layout_column="3" style="@style/CalcButtonOp"/>

        <Button android:id="@+id/btn_4" android:text="4" android:layout_row="1" android:layout_column="0" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_5" android:text="5" android:layout_row="1" android:layout_column="1" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_6" android:text="6" android:layout_row="1" android:layout_column="2" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_mul" android:text="*" android:layout_row="1" android:layout_column="3" style="@style/CalcButtonOp"/>

        <Button android:id="@+id/btn_1" android:text="1" android:layout_row="2" android:layout_column="0" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_2" android:text="2" android:layout_row="2" android:layout_column="1" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_3" android:text="3" android:layout_row="2" android:layout_column="2" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_sub" android:text="-" android:layout_row="2" android:layout_column="3" style="@style/CalcButtonOp"/>

        <Button android:id="@+id/btn_0" android:text="0" android:layout_row="3" android:layout_column="0" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_clear" android:text="C" android:layout_row="3" android:layout_column="1" style="@style/CalcButton"/>
        <Button android:id="@+id/btn_eq" android:text="=" android:layout_row="3" android:layout_column="2" style="@style/CalcButtonEq"/>
        <Button android:id="@+id/btn_add" android:text="+" android:layout_row="3" android:layout_column="3" style="@style/CalcButtonOp"/>

    </GridLayout>
</LinearLayout>
